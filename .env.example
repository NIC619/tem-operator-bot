TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here
GMAIL_CREDENTIALS_JSON_PATH=./credentials.json
GMAIL_TOKEN_PATH=./gmail_token.json

# Tunables — fill in after running /getid in the group.
TELEGRAM_GROUP_CHAT_ID=-1001234567890
TELEGRAM_OPERATOR_USER_ID=123456789
TELEGRAM_POLL_INTERVAL_SECONDS=3
GMAIL_POLL_INTERVAL_SECONDS=300
# Supports decimals: 0.01 ≈ 15 minutes, useful for testing.
WORKFLOW_FOLLOWUP_INTERVAL_DAYS=14

# Optional path overrides (used on Railway to point at the /data volume)
# DB_PATH=./tem_bot.db
# CONFIG_PATH=./config.yaml
# HEADLESS=1   # set to 1 in production to refuse OAuth browser flow
